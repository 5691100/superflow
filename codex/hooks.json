{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume",
        "hooks": [{
          "type": "command",
          "command": "/bin/bash -lc 'for p in \"$HOME/.codex/skills/superflow/hooks/codex-session-start-recovery.sh\" \"$HOME/.claude/skills/superflow/hooks/codex-session-start-recovery.sh\" \"$HOME/.agents/skills/superflow/hooks/codex-session-start-recovery.sh\"; do [ -f \"$p\" ] && exec /bin/bash \"$p\"; done'",
          "statusMessage": "Loading Superflow recovery bundle"
        }]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [{
          "type": "command",
          "command": "/bin/bash -lc 'for p in \"$HOME/.codex/skills/superflow/hooks/codex-stop-state-dump.sh\" \"$HOME/.claude/skills/superflow/hooks/codex-stop-state-dump.sh\" \"$HOME/.agents/skills/superflow/hooks/codex-stop-state-dump.sh\"; do [ -f \"$p\" ] && exec /bin/bash \"$p\"; done'",
          "timeout": 10
        }]
      }
    ]
  }
}
